# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/install-state.gz

# ─────────────────────────────────────────────────────────────
# Next.js / build output
# ─────────────────────────────────────────────────────────────
/.next/
/out/
/build
/dist

# ─────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────
/coverage
/test-results
/playwright-report
/playwright/.cache
/.playwright-mcp

# Local scratch / screenshots (not part of the project)
/.verify
/.shots

# ─────────────────────────────────────────────────────────────
# Environment variables (never commit secrets)
# ─────────────────────────────────────────────────────────────
.env*
!.env.example

# Service-account / credential files (never commit)
serviceAccount.json
*serviceAccount*.json
*-firebase-adminsdk-*.json
*-credentials.json
*.key

# ─────────────────────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────────────────────
.vercel
.wrangler

# ─────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Editors & OS
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ─────────────────────────────────────────────────────────────
# Brand source + image backups
# Stock-licensed source art and local backups — keep out of public repos.
# ─────────────────────────────────────────────────────────────
/brand/source
/brand/brand-guidelines.html
